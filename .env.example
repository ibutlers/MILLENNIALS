# =============================================================================
# MILLENNIALS CONSTRUYEN | CAPITAL — Environment Variables
# =============================================================================
# Copy this file to shared/.env and adjust values for your environment.
# NEVER commit shared/.env — it contains secrets.
# =============================================================================

# ── Database ──
# PostgreSQL connection string (required)
DATABASE_URL=postgres://realstate:CHANGE_ME@postgres:5432/realstate

# ── Application ──
# Base URL used for CORS, CSRF origin checks, and email links
APP_BASE_URL=http://localhost:3000

# API listen port (default: 3001)
API_PORT=3001

# ── Feature flags ──
# ALL default to false in production until HTTPS/legal readiness
AUTH_ENABLED=false
REGISTRATION_ENABLED=false
EMAIL_DELIVERY_ENABLED=false
ADMIN_ENABLED=false
ADMIN_MEDIA_UPLOAD_ENABLED=false
LEADS_ENABLED=false
DEMO_SEED_ENABLED=false

# ── Session ──
SESSION_TTL_SECONDS=86400
SESSION_COOKIE_SECURE=false

# ── Rate limiting ──
AUTH_RATE_LIMIT_MAX=10
AUTH_RATE_LIMIT_WINDOW_MS=900000
LEADS_RATE_LIMIT_MAX=10
LEADS_RATE_LIMIT_WINDOW_MS=900000

# ── Email verification ──
EMAIL_VERIFICATION_TTL_SECONDS=86400
PASSWORD_RESET_TTL_SECONDS=3600

# ── Privacy ──
PRIVACY_CONTROLLER_NAME=
PRIVACY_CONTACT_EMAIL=
PRIVACY_POLICY_VERSION=

# ── E2E test mode ──
# Only set to true in isolated E2E environments (never in production)
E2E_TEST_MODE=false
# Internal secret for E2E test token endpoints (ephemeral, per-run)
E2E_INTERNAL_SECRET=

# ── Provider selection ──
# All providers default to "disabled". Set to a registered provider name
# when the real integration is configured and ready to activate.
# Currently available: disabled
PROVIDER_EMAIL=disabled
PROVIDER_STORAGE=disabled
PROVIDER_KYC=disabled
PROVIDER_SIGNATURE=disabled
PROVIDER_PAYMENTS=disabled
