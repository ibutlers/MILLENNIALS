# =============================================================================
# MILLENNIALS CONSTRUYEN | CAPITAL — Environment Variables
# =============================================================================
# Copy this file to shared/.env and adjust values for your environment.
# NEVER commit shared/.env — it contains secrets.
# =============================================================================

# ── Database ──
# PostgreSQL connection string (required)
DATABASE_URL=postgres://realstate:change-me-in-production@postgres:5432/realstate

# ── Application ──
APP_BASE_URL=http://localhost:3000
API_PORT=3001

# ── Feature flags ──
# ALL default to disabled in production until HTTPS/legal readiness

# Modo de autenticacion: disabled | better-auth
AUTH_MODE=disabled

# Registro publico (solo informativo, el acceso real es por invitacion)
REGISTRATION_ENABLED=false
EMAIL_DELIVERY_ENABLED=false
ADMIN_ENABLED=false
ADMIN_MEDIA_UPLOAD_ENABLED=false
LEADS_ENABLED=false
DEMO_SEED_ENABLED=false

# ── Rate limiting ──
AUTH_RATE_LIMIT_MAX=10
AUTH_RATE_LIMIT_WINDOW_MS=900000
LEADS_RATE_LIMIT_MAX=10
LEADS_RATE_LIMIT_WINDOW_MS=900000

# ── Email verification ──
EMAIL_VERIFICATION_TTL_SECONDS=86400
PASSWORD_RESET_TTL_SECONDS=3600

# ── Better Auth ──
# Secret para firmar cookies y tokens (minimo 32 caracteres, generar con: openssl rand -base64 48)
BETTER_AUTH_SECRET=

# URL base de la API de autenticacion (debe coincidir con APP_BASE_URL)
BETTER_AUTH_URL=

# Origenes de confianza para CORS (separados por coma)
BETTER_AUTH_TRUSTED_ORIGINS=

# Hosts permitidos
BETTER_AUTH_ALLOWED_HOSTS=

# Prefijo de cookies de Better Auth (default: mc)
BETTER_AUTH_COOKIE_PREFIX=mc

# Exigir 2FA para todos los usuarios (default: false; MFA es opcional por defecto)
BETTER_AUTH_REQUIRE_2FA=false

# Override temporal para pruebas reales sobre http://65.108.251.196:8088.
# No usar para ningun otro host. Eliminar al pasar a dominio + HTTPS.
AUTH_ALLOW_INSECURE_IP_TEST=false

# ── Email ──
# Modo de envio de correo: disabled | capture | smtp
AUTH_EMAIL_MODE=disabled

# Remitente y reply-to
AUTH_EMAIL_FROM=
AUTH_EMAIL_REPLY_TO=

# Configuracion SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=

# ── Invitaciones ──
AUTH_INVITATION_TTL_HOURS=48
AUTH_SESSION_EXPIRES_HOURS=8
AUTH_PASSWORD_MIN_LENGTH=12

# ── Privacy ──
PRIVACY_CONTROLLER_NAME=
PRIVACY_CONTACT_EMAIL=
PRIVACY_POLICY_VERSION=

# ── E2E test mode ──
E2E_TEST_MODE=false
E2E_INTERNAL_SECRET=

# ── Provider selection ──
PROVIDER_EMAIL=disabled
PROVIDER_STORAGE=disabled
PROVIDER_KYC=disabled
PROVIDER_SIGNATURE=disabled
PROVIDER_PAYMENTS=disabled
