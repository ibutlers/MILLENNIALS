COMPOSE_PROJECT_NAME=current
NODE_ENV=production
REALSTATE_HTTP_PORT=8088
CADDY_DOMAIN=:80
API_PORT=3001
API_HOST=0.0.0.0
DATABASE_URL=postgres://realstate:change-me-outside-git@postgres:5432/realstate
DATABASE_POOL_MAX=10
DATABASE_STATEMENT_TIMEOUT_MS=5000
DATABASE_QUERY_TIMEOUT_MS=6000
# Optional PostgreSQL readiness controls used by scripts/deploy.sh before backup and migrations.
REALSTATE_POSTGRES_READY_ATTEMPTS=30
REALSTATE_POSTGRES_READY_SLEEP=2
POSTGRES_USER=realstate
POSTGRES_PASSWORD=change-me-outside-git
POSTGRES_DB=realstate

# Lead capture stays disabled until real legal/privacy details are configured outside Git.
LEADS_ENABLED=false
PRIVACY_CONTROLLER_NAME=
PRIVACY_CONTACT_EMAIL=
PRIVACY_POLICY_VERSION=2026-06-14
LEADS_RATE_LIMIT_MAX=5
LEADS_RATE_LIMIT_WINDOW_MS=900000

# Authentication stays disabled until HTTPS and a real domain are configured.
# When enabled, APP_BASE_URL MUST use https://.
AUTH_ENABLED=false
REGISTRATION_ENABLED=false
EMAIL_DELIVERY_ENABLED=false
APP_BASE_URL=http://65.108.251.196:8088
SESSION_COOKIE_SECURE=true
SESSION_TTL_SECONDS=86400
SESSION_IDLE_TTL_SECONDS=3600
EMAIL_VERIFICATION_TTL_SECONDS=1800
PASSWORD_RESET_TTL_SECONDS=1800
AUTH_RATE_LIMIT_MAX=10
AUTH_RATE_LIMIT_WINDOW_MS=900000

# Admin panel stays disabled until auth is live with HTTPS.
ADMIN_ENABLED=false
ADMIN_MEDIA_UPLOAD_ENABLED=false
# Only enable demo seed in dev/staging. Must be false in production.
DEMO_SEED_ENABLED=false
