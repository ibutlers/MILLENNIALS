{
  "name": "realstate",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:e2e": "pnpm --filter @realstate/web test:e2e",
    "build": "pnpm -r build",
    "leads:summary": "pnpm --filter @realstate/api leads:summary",
    "leads:list": "pnpm --filter @realstate/api leads:list",
    "leads:update": "pnpm --filter @realstate/api leads:update",
    "users:list": "pnpm --filter @realstate/api users:list",
    "users:create-admin": "pnpm --filter @realstate/api users:create-admin",
    "users:disable": "pnpm --filter @realstate/api users:disable",
    "users:revoke-sessions": "pnpm --filter @realstate/api users:revoke-sessions",
    "test:e2e:admin": "pnpm --filter @realstate/web test:e2e:admin",
    "test:e2e:investor": "pnpm --filter @realstate/web test:e2e:investor",
    "test:e2e:investor:smoke": "pnpm --filter @realstate/web test:e2e:investor:smoke",
    "test:e2e:admin:setup": "bash scripts/e2e-admin-setup.sh",
    "test:e2e:admin:teardown": "bash scripts/e2e-admin-teardown.sh",
    "test:e2e:auth": "bash scripts/run-e2e-auth.sh"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.48.0",
    "@typescript-eslint/parser": "^8.48.0",
    "eslint": "^9.39.1",
    "typescript": "^5.9.3"
  }
}
